{
    "name":  "Johnny-project-team-plugin",
    "version":  "2.1.1",
    "description":  "Orchestrates a highly modular, TDD-driven multi-agent development team with Hooks and ECC methodology. Contains PM orchestrator and native subagents.",
    "author":  {
                   "name":  "Johnny Team"
               },
    "keywords":  [
                     "team",
                     "project",
                     "pm",
                     "dqa",
                     "architect",
                     "engineer"
                 ],
    "hooks":  [
                  {
                      "command":  "powershell -Command \"python $HOME/.gemini/config/plugins/Johnny-project-team-plugin/skills/Johnny-project-team/scripts/workspace_init.py\"",
                      "name":  "Auto-Scaffold Workspace",
                      "event":  "SessionStart"
                  }
              ]
}
